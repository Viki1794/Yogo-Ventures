# ── App Configuration ──────────────────────────────────
REACT_APP_NAME=Coastal Retreat
REACT_APP_VERSION=1.0.0
REACT_APP_BASE_URL=https://www.coastalretreat.in

# ── CMS Integration (Sanity) ────────────────────────────
# Replace with your actual Sanity project credentials
REACT_APP_SANITY_PROJECT_ID=your_project_id
REACT_APP_SANITY_DATASET=production
REACT_APP_SANITY_API_VERSION=2024-01-01

# ── Analytics ───────────────────────────────────────────
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Payment Gateway (Razorpay) ──────────────────────────
REACT_APP_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# ── Feature Flags ───────────────────────────────────────
REACT_APP_ENABLE_GSAP=true
REACT_APP_ENABLE_360_VIEWER=true
REACT_APP_ENABLE_WISHLIST=true
